# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small

# Vector store
VECTOR_STORE_BACKEND=faiss
FAISS_INDEX_PATH=faiss_index
RAG_TOP_K=5

# Optional: Pinecone (set VECTOR_STORE_BACKEND=pinecone to use)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=rca-index

# API server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
RELOAD=false

# CORS (comma-separated list of origins, or * to allow all)
CORS_ORIGINS=*
