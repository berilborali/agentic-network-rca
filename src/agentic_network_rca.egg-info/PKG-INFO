│       │   └── report_agent.py
│       ├── models/
│       │   └── network_event.py       # Pydantic data models
│       ├── utils/
│       │   └── metrics.py             # Statistical helpers
│       ├── orchestrator.py            # Pipeline coordinator
│       └── cli.py                     # `network-rca` CLI entry point
├── examples/
│   ├── run_rca.py                     # Quick demo script
│   └── generate_sample_data.py        # Generate a sample JSON dataset
├── data/
│   └── sample_congestion.json         # Pre-generated sample data
├── tests/
│   ├── test_agents.py
│   └── test_orchestrator.py
├── pyproject.toml
